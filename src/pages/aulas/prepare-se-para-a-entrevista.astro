                </div>
              </div><h1 class="single-lesson_title">PreparatĂłrio TĂŠcnico</h1><div
                class="lesson_card-meta-wrapper w-condition-invisible"
              >
                <div class="lesson_card-meta-user-wrapper">
                  <img
                    src="/cdn-assets/images/graphics/illustrations/graphic-illustration-9.avif"
